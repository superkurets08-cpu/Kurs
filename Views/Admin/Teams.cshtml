@model IEnumerable<Team>

@{
    ViewData["Title"] = "Управление командами";
}

<div class="page-container">
    <section class="hero">
        <h1>Команды</h1>
        <p>Управление карточками команд и внешними ссылками.</p>
    </section>

    <section class="panel">
        <div class="actions-row">
            <a class="btn-link" asp-action="CreateTeam">Добавить команду</a>
            <a class="btn-secondary" asp-action="Index">Назад в админ-панель</a>
        </div>

        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Страна</th>
                        <th>Ссылка</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var team in Model)
                {
                    <tr>
                        <td>@team.TeamName</td>
                        <td>@team.Country</td>
                        <td>@team.team_url</td>
                        <td class="table-actions">
                            <a class="btn-secondary" asp-action="EditTeam" asp-route-id="@team.TeamID">Изменить</a>
                            <form asp-action="DeleteTeam" method="post" onsubmit="return confirm('Удалить команду?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@team.TeamID" />
                                <button class="btn-danger" type="submit">Удалить</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</div>
