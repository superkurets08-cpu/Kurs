@model IEnumerable<Player>

@{
    ViewData["Title"] = "Управление игроками";
}

<div class="page-container">
    <section class="hero">
        <h1>Игроки</h1>
        <p>Редактирование игроков, ролей, команд и аватарок.</p>
    </section>

    <section class="panel">
        <div class="actions-row">
            <a class="btn-link" asp-action="CreatePlayer">Добавить игрока</a>
            <a class="btn-secondary" asp-action="Index">Назад в админ-панель</a>
        </div>

        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Игрок</th>
                        <th>Имя</th>
                        <th>Страна</th>
                        <th>Роль</th>
                        <th>Команда</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var player in Model)
                {
                    <tr>
                        <td>
                            <div class="entity-cell">
                                @if (!string.IsNullOrWhiteSpace(player.AvatarUrl))
                                {
                                    <img class="avatar avatar--sm" src="@player.AvatarUrl" alt="Аватар игрока @player.Nickname" />
                                }
                                else
                                {
                                    <div class="avatar avatar--sm avatar--fallback">@AvatarHelper.GetInitials(player.Nickname)</div>
                                }
                                <span>@player.Nickname</span>
                            </div>
                        </td>
                        <td>@player.RealName</td>
                        <td>@player.Country</td>
                        <td>@player.Role</td>
                        <td>@(player.CurrentTeam?.TeamName ?? player.Team)</td>
                        <td class="table-actions">
                            <a class="btn-secondary" asp-action="EditPlayer" asp-route-id="@player.PlayerID">Изменить</a>
                            <form asp-action="DeletePlayer" method="post" onsubmit="return confirm('Удалить игрока?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@player.PlayerID" />
                                <button class="btn-danger" type="submit">Удалить</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</div>
