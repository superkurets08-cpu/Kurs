@model HomeIndexViewModel

@{
    ViewData["Title"] = "Главная";
}

<div class="page-container">
    <section class="hero hero--home reveal">
        <div class="hero__eyebrow">The International Knowledge Hub</div>
        <h1>Архив Dota 2, который ощущается как полноценный киберспортивный портал.</h1>
        <p>Турниры, команды, игроки и справочная база собраны в одном месте, чтобы по проекту было видно не только CRUD, но и продуманную навигацию, поиск и структуру данных.</p>
        <div class="hero__actions">
            <a class="btn-link" asp-controller="Home" asp-action="Tournaments">Открыть турниры</a>
            <a class="btn-secondary" asp-controller="Home" asp-action="Teams">Смотреть команды</a>
        </div>
        <div class="hero-feature-strip">
            <article class="hero-feature">
                <span class="hero-feature__label">Фокус</span>
                <strong>История TI</strong>
            </article>
            <article class="hero-feature">
                <span class="hero-feature__label">Формат</span>
                <strong>Archive + Wiki</strong>
            </article>
            <article class="hero-feature">
                <span class="hero-feature__label">Уровень доступа</span>
                <strong>Гость / User / Admin</strong>
            </article>
        </div>
    </section>

    <section class="stats-grid reveal">
        <article class="stat-card stat-card--accent">
            <span class="stat-card__label">Турниры</span>
            <strong class="stat-card__value">@Model.TournamentsCount</strong>
        </article>
        <article class="stat-card">
            <span class="stat-card__label">Команды</span>
            <strong class="stat-card__value">@Model.TeamsCount</strong>
        </article>
        <article class="stat-card">
            <span class="stat-card__label">Игроки</span>
            <strong class="stat-card__value">@Model.PlayersCount</strong>
        </article>
        <article class="stat-card">
            <span class="stat-card__label">Герои</span>
            <strong class="stat-card__value">@Model.HeroesCount</strong>
        </article>
    </section>

    <section class="panel reveal">
        <div class="section-heading">
            <div>
                <div class="section-kicker">Сценарии использования</div>
                <h2>Проект уже разделён по ролям и сценариям</h2>
            </div>
        </div>
        <div class="card-grid card-grid--three">
            <article class="tile tile--feature">
                <h3>Гость</h3>
                <p class="muted">Видит главную страницу, турниры, команды, детальные карточки и может пользоваться глобальным поиском по открытым разделам.</p>
            </article>
            <article class="tile tile--feature">
                <h3>Авторизованный пользователь</h3>
                <p class="muted">Получает доступ к расширенным разделам: игрокам, героям, предметам, а также к более глубокому поиску и профилям игроков.</p>
            </article>
            <article class="tile tile--feature">
                <h3>Администратор</h3>
                <p class="muted">Управляет всеми сущностями через админ-панель и расширяет архив без прямой работы с базой данных.</p>
            </article>
        </div>
    </section>

    <section class="panel reveal">
        <div class="section-heading">
            <div>
                <div class="section-kicker">Быстрый переход</div>
                <h2>Ключевые разделы для просмотра</h2>
            </div>
        </div>
        <div class="card-grid card-grid--three">
            <a class="tile" asp-controller="Home" asp-action="Tournaments">
                <h3>Турниры</h3>
                <p class="muted">Хронология TI, фильтрация по году и поиск по чемпионам и локациям.</p>
            </a>
            <a class="tile" asp-controller="Home" asp-action="Teams">
                <h3>Команды</h3>
                <p class="muted">Карточки клубов, составы, матчи и удобная фильтрация по странам.</p>
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="tile" asp-controller="Home" asp-action="Players">
                    <h3>Игроки</h3>
                    <p class="muted">Профили игроков, роли, страны, команды и последние матчи.</p>
                </a>
            }
            else
            {
                <a class="tile" asp-controller="Account" asp-action="Login">
                    <h3>Игроки</h3>
                    <p class="muted">Раздел с расширенными данными доступен после входа в систему.</p>
                </a>
            }
        </div>
    </section>

    <section class="panel reveal">
        <div class="section-heading">
            <div>
                <div class="section-kicker">Последние записи</div>
                <h2>Свежие турниры в архиве</h2>
            </div>
            <a class="btn-secondary" asp-controller="Home" asp-action="Search">Глобальный поиск</a>
        </div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Год</th>
                        <th>Турнир</th>
                        <th>Локация</th>
                        <th>Победитель</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var tournament in Model.RecentTournaments)
                {
                    <tr>
                        <td>@tournament.Year</td>
                        <td>@tournament.TournamentName</td>
                        <td>@tournament.Location</td>
                        <td>@tournament.ChampionTeam</td>
                        <td><a class="btn-link btn-link--small" asp-controller="Home" asp-action="TournamentDetails" asp-route-id="@tournament.TournamentID">Открыть</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</div>
